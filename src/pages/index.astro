---
import "../styles/bingo.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bingo Centenera</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="container">
      <h1>Bingo Centenera</h1>

      <div id="ball" class="bingo-ball">-</div>

      <div class="controls">
        <button id="btn-draw" class="btn btn-primary">
          Sacar número
        </button>
        <button id="btn-reset" class="btn btn-danger">
          Reiniciar
        </button>
      </div>

      
      <div>
         <h4 class="pending-numbers-title">Números pendientes</h4>
        <div id="grid"></div>

      </div>
    </div>
    <div class="drawn-numbers">
        <h4 class="drawn-title">Números sacados</h4>
        <div id="drawn-list" class="drawn-list"></div>
    </div>
      <script>
      import "../scripts/bingo.ts";
    </script>
  </body>
</html>
