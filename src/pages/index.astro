---
import "../styles/bingo.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bingo Fiestas Centenera 2026</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Bingo Fiestas Centenera 2026" />
    <meta property="og:description" content="Bingo de las fiestas de Centenera 2026. ¡Suerte!" />
    <meta property="og:image" content="https://bingo-centenera.pages.dev/og-image.svg" />
    <meta property="og:url" content="https://bingo-centenera.pages.dev" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="container">
      <h1>Bingo Centenera</h1>
      <div id="ball" class="bingo-ball">-</div>
      <div class="controls">
        <button id="btn-draw" class="btn btn-primary btn-draw">
          Sacar número
        </button>
      </div>
      <div class="grid-numbers">
        <h4>Números pendientes</h4>
        <div id="grid" class="number-grid"></div>
      </div>
      <div class="grid-numbers">
        <h4>Números sacados</h4>
        <div id="drawn-list" class="number-grid"></div>
      </div>
      <p id="game-over-msg" class="game-over-message hidden"></p>
    </div>
    <div class="reset-container">
      <button id="btn-reset" class="btn btn-danger">
        Reiniciar
      </button>
    </div>

    <div
      id="modal-overlay"
      class="modal-overlay hidden"
    >
      <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
        <div class="modal-header">
          <h3 id="modal-title">Reiniciar partida</h3>
          <button id="btn-new-equation" class="btn-icon" title="Nueva ecuación" aria-label="Generar nueva ecuación">↻</button>
        </div>
        <p>Resuelve la siguiente ecuación para confirmar:</p>
        <p id="equation" class="equation"></p>
        <input
          id="equation-answer"
          type="text"
          inputmode="numeric"
          class="modal-input"
          placeholder="Resultado"
          autocomplete="off"
          aria-describedby="equation-error"
          aria-invalid="false"
        />
        <p id="equation-error" class="equation-error hidden">Respuesta incorrecta</p>
        <div class="modal-actions">
          <button id="btn-modal-confirm" class="btn btn-primary">Confirmar</button>
          <button id="btn-modal-cancel" class="btn btn-danger">Cancelar</button>
        </div>
      </div>
    </div>

    <script>
      import "../scripts/bingo.ts";
    </script>
  </body>
</html>
