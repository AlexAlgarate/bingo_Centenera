---
import "../styles/bingo.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bingo Fiestas Centenera 2026</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Bingo Fiestas Centenera 2026" />
    <meta property="og:description" content="Bingo de las fiestas de Centenera 2026. ¡Suerte!" />
    <meta property="og:image" content="https://bingo-centenera.pages.dev/og-image.svg" />
    <meta property="og:url" content="https://bingo-centenera.pages.dev" />
    <meta name="twitter:card" content="summary_large_image" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="container">
      <h1>Bingo Centenera</h1>
      <div id="ball" class="bingo-ball">-</div>
      <div class="controls">
        <button id="btn-draw" class="btn btn-primary btn-draw">
          Sacar número
        </button>
      </div>
      <div class="grid-numbers">
        <h4 class="pending-numbers-title">Números pendientes</h4>
        <div id="grid" class="number-grid"></div>
      </div>
      <div class="grid-numbers">
          <h4 class="drawn-title">Números sacados</h4>
          <div id="drawn-list" class="number-grid"></div>
      </div>
    </div>
    <div class="reset-container">
      <button id="btn-reset" class="btn btn-danger">
        Reiniciar
      </button>
    </div>

    <div id="modal-overlay" class="modal-overlay hidden">
      <div class="modal">
        <h3>Reiniciar partida</h3>
        <p>Resuelve la siguiente ecuación para confirmar:</p>
        <p id="equation" class="equation"></p>
        <input id="equation-answer" type="number" class="modal-input" placeholder="Resultado" autofocus />
        <p id="equation-error" class="equation-error hidden">Respuesta incorrecta</p>
        <div class="modal-actions">
          <button id="btn-modal-confirm" class="btn btn-primary">Confirmar</button>
          <button id="btn-modal-cancel" class="btn btn-danger">Cancelar</button>
        </div>
      </div>
    </div>

      <script>
      import "../scripts/bingo.ts";
    </script>
  </body>
</html>
